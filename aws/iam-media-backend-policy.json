{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BroadcastMediaPutObject",
      "Effect": "Allow",
      "Action": ["s3:PutObject"],
      "Resource": "arn:aws:s3:::siasa-broadcast-media/broadcast/*"
    },
    {
      "Sid": "BroadcastMediaListPrefix",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::siasa-broadcast-media",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["broadcast/*"]
        }
      }
    }
  ]
}

# Copy to .env and fill in values. For Vercel, add the same MPESA_* variables in Project Settings.

MONGO_URI=

# Optional: comma-separated DNS servers for mongodb+srv on Windows (default 8.8.8.8,8.8.4.4)
# MONGO_DNS_SERVERS=8.8.8.8,8.8.4.4

MPESA_ENV=sandbox
MPESA_SHORTCODE=174379
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
# Lipa Na M-Pesa Online passkey from Daraja portal (sandbox default below)
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
ADMIN_API_KEY=
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
MPESA_CALLBACK_URL=https://YOUR-API-HOST/api/mpesa/callback

# Skip Daraja during local UI testing
# MPESA_MOCK=true
# Sandbox: auto-complete STK after ~15s when no PIN prompt (default on sandbox)
# MPESA_SANDBOX_AUTO_COMPLETE=false

# AI provider gateway. OPEN_ROUTER_API_KEY powers Gemini/GPT-compatible chat and embeddings.
OPEN_ROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
AI_FAST_MODEL=google/gemini-2.0-flash-001
AI_REASONING_MODEL=google/gemini-2.0-flash-001
APP_PUBLIC_URL=https://broadcast.africa

# AI search and workers
ATLAS_VECTOR_INDEX=embedding_vector_index
AI_REDIS_URL=
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
AI_RATE_LIMIT_PER_MIN=60

# AI voice/transcription
DEEPGRAM_API_KEY=

# Phase 2 media moderation placeholder
GCP_VISION_KEY=

# Agora RTC (video/voice/live — token auth)
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# Stream Chat (unchanged)
STREAM_API_KEY=
STREAM_API_SECRET=
